<Window x:Class="OmniMark.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OmniMark - Settings"
        Width="450"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Margin" Value="0,4,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Padding" Value="4,2" />
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="Margin" Value="4,0" />
        </Style>
        <Style x:Key="SmallButton" TargetType="Button">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="ValueTextBox" TargetType="TextBox">
            <Setter Property="Width" Value="50" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <StackPanel Margin="16">

        <!-- Preset Configuration -->
        <Label Content="Preset:" FontWeight="SemiBold" />
        <Grid Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="CmbPresets" Grid.Column="0" 
                      SelectionChanged="CmbPresets_SelectionChanged" />
            <Button x:Name="BtnSavePreset" Grid.Column="1" Content="Save" 
                    Style="{StaticResource SmallButton}" Click="BtnSavePreset_Click" />
            <Button x:Name="BtnSaveAsPreset" Grid.Column="2" Content="Save As..." 
                    Style="{StaticResource SmallButton}" Click="BtnSaveAsPreset_Click" />
            <Button x:Name="BtnDeletePreset" Grid.Column="3" Content="Delete" 
                    Style="{StaticResource SmallButton}" Click="BtnDeletePreset_Click" />
        </Grid>

        <Separator Margin="0,12,0,8" />

        <!-- Watermark Text -->
        <Label Content="Watermark Text:" FontWeight="SemiBold" />
        <TextBox x:Name="TxtWatermarkText" />

        <!-- Font Family -->
        <Label Content="Font:" FontWeight="SemiBold" />
        <ComboBox x:Name="CmbFontFamily" Margin="0,4,0,0" />

        <!-- Font Size -->
        <Label Content="Font Size:" FontWeight="SemiBold" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Slider x:Name="SliderFontSize" Grid.Column="0"
                    Minimum="12" Maximum="120" TickFrequency="1" IsSnapToTickEnabled="True"
                    ValueChanged="SliderFontSize_ValueChanged" />
            <TextBox x:Name="TxtFontSizeValue" Grid.Column="1" Style="{StaticResource ValueTextBox}"
                     LostFocus="TxtFontSizeValue_LostFocus" KeyDown="TxtFontSizeValue_KeyDown" />
        </Grid>

        <!-- Opacity -->
        <Label Content="Opacity (%):" FontWeight="SemiBold" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Slider x:Name="SliderOpacity" Grid.Column="0"
                    Minimum="0.01" Maximum="1.0" TickFrequency="0.01" IsSnapToTickEnabled="False"
                    ValueChanged="SliderOpacity_ValueChanged" />
            <TextBox x:Name="TxtOpacityValue" Grid.Column="1" Style="{StaticResource ValueTextBox}"
                     LostFocus="TxtOpacityValue_LostFocus" KeyDown="TxtOpacityValue_KeyDown" />
        </Grid>

        <!-- Rotation Angle -->
        <Label Content="Rotation Angle:" FontWeight="SemiBold" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Slider x:Name="SliderAngle" Grid.Column="0"
                    Minimum="-90" Maximum="90" TickFrequency="1" IsSnapToTickEnabled="True"
                    ValueChanged="SliderAngle_ValueChanged" />
            <TextBox x:Name="TxtAngleValue" Grid.Column="1" Style="{StaticResource ValueTextBox}"
                     LostFocus="TxtAngleValue_LostFocus" KeyDown="TxtAngleValue_KeyDown" />
        </Grid>

        <!-- Text Colour -->
        <Label Content="Text Color:" FontWeight="SemiBold" />
        <Grid Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border x:Name="ColorPreview" Grid.Column="0" Width="24" Height="24" 
                    BorderBrush="Gray" BorderThickness="1" CornerRadius="2" Margin="0,0,8,0" />
            <TextBox x:Name="TxtColor" Grid.Column="1" TextChanged="TxtColor_TextChanged" />
            <Button x:Name="BtnPickColor" Grid.Column="2" Content="Pick..." 
                    Style="{StaticResource SmallButton}" Click="BtnPickColor_Click" />
            <Button x:Name="BtnScreenPick" Grid.Column="3" Content="Screen" 
                    Style="{StaticResource SmallButton}" Click="BtnScreenPick_Click" />
        </Grid>

        <!-- Spacing X -->
        <Label Content="Horizontal Spacing (px):" FontWeight="SemiBold" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Slider x:Name="SliderSpacingX" Grid.Column="0"
                    Minimum="50" Maximum="600" TickFrequency="10" IsSnapToTickEnabled="True"
                    ValueChanged="SliderSpacingX_ValueChanged" />
            <TextBox x:Name="TxtSpacingXValue" Grid.Column="1" Style="{StaticResource ValueTextBox}"
                     LostFocus="TxtSpacingXValue_LostFocus" KeyDown="TxtSpacingXValue_KeyDown" />
        </Grid>

        <!-- Spacing Y -->
        <Label Content="Vertical Spacing (px):" FontWeight="SemiBold" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Slider x:Name="SliderSpacingY" Grid.Column="0"
                    Minimum="50" Maximum="600" TickFrequency="10" IsSnapToTickEnabled="True"
                    ValueChanged="SliderSpacingY_ValueChanged" />
            <TextBox x:Name="TxtSpacingYValue" Grid.Column="1" Style="{StaticResource ValueTextBox}"
                     LostFocus="TxtSpacingYValue_LostFocus" KeyDown="TxtSpacingYValue_KeyDown" />
        </Grid>

        <!-- Cover Taskbar -->
        <CheckBox x:Name="ChkCoverTaskbar" Content="Cover Taskbar" Margin="0,12,0,0" />

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Apply" Click="Apply_Click" IsDefault="True" />
            <Button Content="Cancel" Click="Cancel_Click" IsCancel="True" />
        </StackPanel>

    </StackPanel>
</Window>
