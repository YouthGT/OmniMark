<Window x:Class="OmniMark.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OmniMark – Settings"
        Width="400"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Margin" Value="0,4,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Padding" Value="4,2" />
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="Margin" Value="4,0" />
        </Style>
    </Window.Resources>

    <StackPanel Margin="16">

        <!-- Watermark Text -->
        <Label Content="Watermark text:" FontWeight="SemiBold" />
        <TextBox x:Name="TxtWatermarkText" />

        <!-- Font Size -->
        <Label Content="Font size:" FontWeight="SemiBold" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
            </Grid.ColumnDefinitions>
            <Slider x:Name="SliderFontSize" Grid.Column="0"
                    Minimum="12" Maximum="120" TickFrequency="1" IsSnapToTickEnabled="True"
                    ValueChanged="SliderFontSize_ValueChanged" />
            <TextBlock x:Name="TxtFontSizeValue" Grid.Column="1"
                       VerticalAlignment="Center" HorizontalAlignment="Right" />
        </Grid>

        <!-- Opacity -->
        <Label Content="Opacity:" FontWeight="SemiBold" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
            </Grid.ColumnDefinitions>
            <Slider x:Name="SliderOpacity" Grid.Column="0"
                    Minimum="0.01" Maximum="1.0" TickFrequency="0.01" IsSnapToTickEnabled="False"
                    ValueChanged="SliderOpacity_ValueChanged" />
            <TextBlock x:Name="TxtOpacityValue" Grid.Column="1"
                       VerticalAlignment="Center" HorizontalAlignment="Right" />
        </Grid>

        <!-- Rotation Angle -->
        <Label Content="Rotation angle (°):" FontWeight="SemiBold" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
            </Grid.ColumnDefinitions>
            <Slider x:Name="SliderAngle" Grid.Column="0"
                    Minimum="-90" Maximum="90" TickFrequency="1" IsSnapToTickEnabled="True"
                    ValueChanged="SliderAngle_ValueChanged" />
            <TextBlock x:Name="TxtAngleValue" Grid.Column="1"
                       VerticalAlignment="Center" HorizontalAlignment="Right" />
        </Grid>

        <!-- Text Colour -->
        <Label Content="Text colour (hex, e.g. #808080):" FontWeight="SemiBold" />
        <TextBox x:Name="TxtColor" />

        <!-- Spacing X -->
        <Label Content="Horizontal spacing (px):" FontWeight="SemiBold" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="50" />
            </Grid.ColumnDefinitions>
            <Slider x:Name="SliderSpacingX" Grid.Column="0"
                    Minimum="50" Maximum="600" TickFrequency="10" IsSnapToTickEnabled="True"
                    ValueChanged="SliderSpacingX_ValueChanged" />
            <TextBlock x:Name="TxtSpacingXValue" Grid.Column="1"
                       VerticalAlignment="Center" HorizontalAlignment="Right" />
        </Grid>

        <!-- Spacing Y -->
        <Label Content="Vertical spacing (px):" FontWeight="SemiBold" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="50" />
            </Grid.ColumnDefinitions>
            <Slider x:Name="SliderSpacingY" Grid.Column="0"
                    Minimum="50" Maximum="600" TickFrequency="10" IsSnapToTickEnabled="True"
                    ValueChanged="SliderSpacingY_ValueChanged" />
            <TextBlock x:Name="TxtSpacingYValue" Grid.Column="1"
                       VerticalAlignment="Center" HorizontalAlignment="Right" />
        </Grid>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Apply" Click="Apply_Click" IsDefault="True" />
            <Button Content="Cancel" Click="Cancel_Click" IsCancel="True" />
        </StackPanel>

    </StackPanel>
</Window>
