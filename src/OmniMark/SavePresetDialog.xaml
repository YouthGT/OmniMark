<Window x:Class="OmniMark.SavePresetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Save Preset"
        Width="350"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <StackPanel Margin="16">
        <Label Content="Preset Name:" FontWeight="SemiBold" />
        <TextBox x:Name="TxtPresetName" Margin="0,4,0,0" Padding="4,2" />
        
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Save" Padding="16,6" Margin="4,0" Click="BtnSave_Click" IsDefault="True" />
            <Button Content="Cancel" Padding="16,6" Margin="4,0" Click="BtnCancel_Click" IsCancel="True" />
        </StackPanel>
    </StackPanel>
</Window>
